# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
wheels/
*.egg-info/
.eggs/

# ---- uv / virtualenv ----
.venv/
venv/
env/
# NOTE: uv.lock is intentionally NOT ignored — it is committed for reproducible installs.

# ---- Test / type / lint caches ----
.pytest_cache/
.ruff_cache/
.mypy_cache/
.dmypy.json
.coverage
.coverage.*
htmlcov/
coverage.xml

# ---- Jupyter ----
.ipynb_checkpoints/

# ---- Model weights, baked artifacts, runtime caches (NEVER commit) ----
# Source checkpoints, baked artifacts, and their sibling *_offload caches live
# OUTSIDE the repo (under ~/models). These globs are a backstop in case any land
# inside the tree by mistake. The baked artifact is an immutable bundle; the
# runtime offload state belongs in a sibling <artifact>_offload dir.
*.safetensors
*.gguf
*.bin
*.pt
*.npz
*.npy
models/
artifacts/
*_offload/
calibration/
*.calib
scratch/

# ---- macOS / editors ----
.DS_Store
.AppleDouble
.LSOverride
._*
.idea/
.vscode/
*.swp

# ---- Claude Code (local agent state / settings) ----
# Ignore everything under .claude/ (worktrees, settings, local state) EXCEPT the committed
# agent-memory snapshot below — the project "brain" is tracked so it travels with the repo and
# survives a machine reformat without a separate ~/.claude backup. Restore it to the per-project
# Claude memory dir on a fresh machine via scripts/restore_claude_memory.sh.
.claude/*
!.claude/memory/
